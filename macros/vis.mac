# Visualization (OpenGL Qt). Adjust the driver to your Geant4 build.
/vis/open OGL 900x900-0+0
/vis/viewer/set/autoRefresh false
/vis/verbose errors

/vis/drawVolume
/vis/viewer/set/viewpointThetaPhi 70 20
/vis/viewer/set/style surface
/vis/viewer/set/auxiliaryEdge true
/vis/viewer/zoom 1.4

# Draw trajectories, accumulate over events, colour by particle.
/vis/scene/add/trajectories smooth
/vis/modeling/trajectories/create/drawByParticleID
/vis/modeling/trajectories/drawByParticleID-0/set e- red
/vis/modeling/trajectories/drawByParticleID-0/set e+ blue
/vis/modeling/trajectories/drawByParticleID-0/set gamma green
/vis/modeling/trajectories/drawByParticleID-0/set opticalphoton yellow
# optical photons are numerous; draw only a fraction for clarity
/vis/filtering/trajectories/create/particleFilter pf
/vis/filtering/trajectories/pf/add opticalphoton
/vis/filtering/trajectories/pf/invert true

/vis/scene/endOfEventAction accumulate
/vis/scene/add/axes 0 0 0 20 mm
/vis/scene/add/scale 14 mm z 1 0 0 manual 0 0 80 mm
/vis/viewer/set/autoRefresh true
